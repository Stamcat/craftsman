{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.storybook.tsbuildinfo",
    "types": ["vite/client", "node"]
  },
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vitest.shims.d.ts",
    "scss.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "scripts/**/*"
  ]
}
