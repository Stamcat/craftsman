{
  "name": "@devinmarra/craftsman",
  "version": "0.0.1-alpha.0",
  "description": "Craftsman Design System",
  "author": "Devin Marra",
  "license": "MIT",
  "types": "index.d.ts",
  "main": "index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/devinmarra/craftsman"
  },
  "publishConfig": {
    "@devinmarra:registry": "https://npm.pkg.github.com"
  },
  "workspaces": [
    "button"
  ],
  "scripts": {
    "build:local": "npm run clean && npm install && npm run build:src && cd lib && npm pack --pack-destination ~",
    "build:src": "npm run compile && tsx ./buildPackage.ts",
    "build:storybook": "storybook build",
    "build:test": "tsx ./buildPackage.ts",
    "check:dependencies:circular": "dependency-cruiser --config qualityChecks/.dependency-cruiser-check-circular.cjs src",
    "check:dependencies:report": "dependency-cruiser --config qualityChecks/.dependency-cruiser-std.cjs -f deps.html -T err-html src",
    "clean": "rm -rf lib && rm -rf tmp && rm -rf dist",
    "commit": "commit",
    "commitlint": "commitlint --edit",
    "compile": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:commit": "eslint --fix --max-warnings=10",
    "lint:fix": "eslint . --fix",
    "lint:package": "npmPkgJsonLint ./package.json",
    "lint:prod": "eslint . --max-warnings=0",
    "lint:sonar": "eslint . -f json -o lintreport.json",
    "lint:staged": "lint-staged --no-stash",
    "prepare": "husky install",
    "pretty": "prettier --write \"src/**/*\"",
    "pretty:commit": "prettier --write",
    "release": "commit-and-tag-version",
    "release:alpha": "npm run release -- --prerelease alpha",
    "release:beta": "npm run release -- --prerelease beta",
    "release:major": "npm run release -- release-as major",
    "release:minor": "npm run release -- release-as minor",
    "release:patch": "npm run release -- release-as patch",
    "start": "set NODE_OPTIONS=--openssl-legacy-provider &&storybook dev -p 6006",
    "start:debug": "storybook dev -p 6006 --debug-webpack",
    "storybook:docker:build": "npm run build:storybook && docker-builder",
    "storybook:docker:push": "docker-push",
    "tag:auto": "tsx ./autoTag.ts",
    "test": "jest --coverage",
    "test:bail": "jest --bail",
    "test:sonar": "jest --coverage --testResultsProcessor 'jest-sonar-reporter'",
    "type-check": "tsc --noEmit",
    "type-check:commit": "npm run type-check --silent",
    "type-check:watch": "npm run type-check -- --watch"
  },
  "dependencies": {
    "@dnd-kit/core": "6.1.0",
    "@dnd-kit/sortable": "8.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@reduxjs/toolkit": "1.9.5",
    "@svgr/webpack": "8.0.1",
    "@types/js-yaml": "4.0.5",
    "@types/styled-components": "5.1.26",
    "axios": "1.6.0",
    "dotenv": "16.3.1",
    "file-loader": "6.2.0",
    "js-yaml": "4.1.0",
    "prop-types": "15.8.1",
    "react": "18.2.0",
    "react-calendar": "4.6.0",
    "react-date-picker": "10.3.0",
    "react-dom": "18.2.0",
    "react-redux": "8.0.7",
    "react-router-dom": "6.16.0",
    "redux-saga": "1.2.3",
    "styled-components": "6.1.0",
    "url-loader": "4.1.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@babel/preset-env": "7.23.5",
    "@babel/preset-react": "7.23.3",
    "@babel/preset-typescript": "7.23.3",
    "@cfaester/enzyme-adapter-react-18": "0.7.1",
    "@commitlint/cli": "17.6.6",
    "@commitlint/config-conventional": "17.6.6",
    "@commitlint/prompt": "17.6.6",
    "@commitlint/prompt-cli": "17.6.6",
    "@storybook/addon-designs": "7.0.9",
    "@storybook/addon-essentials": "7.6.4",
    "@storybook/addon-interactions": "7.6.4",
    "@storybook/addon-links": "7.6.4",
    "@storybook/addon-storysource": "7.6.4",
    "@storybook/addon-styling": "1.3.7",
    "@storybook/addon-themes": "7.6.5",
    "@storybook/blocks": "7.6.4",
    "@storybook/react": "7.6.4",
    "@storybook/react-webpack5": "7.6.4",
    "@storybook/testing-library": "0.0.14-next.2",
    "@styled/typescript-styled-plugin": "1.0.1",
    "@testing-library/react": "13.4.0",
    "@types/enzyme": "3.10.18",
    "@types/fs-extra": "11.0.1",
    "@types/jest": "29.5.11",
    "@types/node": "12.12.21",
    "@types/react": "17.0.2",
    "@types/react-dom": "17.0.1",
    "@types/testing-library__jest-dom": "6.0.0",
    "@typescript-eslint/eslint-plugin": "6.1.0",
    "autoprefixer": "10.4.13",
    "commit-and-tag-version": "11.2.2",
    "dependency-cruiser": "13.1.0",
    "enzyme": "3.11.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-sonarjs": "0.19.0",
    "eslint-plugin-storybook": "0.6.15",
    "fs-extra": "11.2.0",
    "http-server": "14.1.1",
    "husky": "8.0.3",
    "jest": "29.1.2",
    "jest-environment-jsdom": "29.1.2",
    "jest-sonar-reporter": "2.0.0",
    "jest-styled-components": "7.2.0",
    "lint-staged": "13.2.3",
    "npm-package-json-lint": "7.0.0",
    "npm-package-json-lint-config-default": "6.0.0",
    "prettier": "2.8.8",
    "semver": "7.5.4",
    "storybook": "7.6.4",
    "ts-jest": "29.1.1",
    "tsx": "4.6.2",
    "typescript": "5.1.6",
    "webpack": "5.88.2",
    "webpack-merge": "5.8.0"
  },
  "lint-staged": {
    "package-lock.json": "node qualityChecks/check-package-lock.cjs",
    "*.json": "npm run pretty:commit --",
    "src/*.{ts,tsx,js}|*.{ts,tsx}": [
      "npm run lint:commit --fix --silent --"
    ]
  }
}
