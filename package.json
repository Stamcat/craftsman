{
  "name": "@stamcat/craftsman",
  "version": "0.0.23-alpha.4",
  "type": "module",
  "description": "A powerful, lightweight framework for design systems",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stamcat/craftsman.git"
  },
  "keywords": [
    "design system",
    "reusable components"
  ],
  "author": "Devin Marra",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Stamcat/craftsman/issues"
  },
  "types": "index.d.ts",
  "main": "index.js",
  "homepage": "https://github.com/Stamcat/craftsman#readme",
  "scripts": {
    "build": "tsc --p ./tsconfig-build.json && vite build && tsx ./buildPackage.ts",
    "build-storybook": "storybook build",
    "dev": "vite",
    "lint": "eslint . && npm run lint:package",
    "lint:fix": "eslint . --fix",
    "lint:package": "npmPkgJsonLint ./package.json",
    "prepublishOnly": "node ./scripts/prepublishCheck.js",
    "preview": "vite preview",
    "release": "commit-and-tag-version",
    "release:alpha": "npm run release -- --prerelease alpha",
    "release:beta": "npm run release -- --prerelease beta",
    "release:major": "npm run release -- release-as major",
    "release:minor": "npm run release -- release-as minor",
    "release:patch": "npm run release -- release-as patch",
    "storybook": "storybook dev -p 6006",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "dompurify": "3.4.11",
    "emotion": "11.0.0",
    "react": "19.2.7",
    "react-date-picker": "12.0.2",
    "react-datetime-picker": "7.0.2",
    "react-dom": "19.2.7",
    "react-international-phone": "4.8.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-themes": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@types/fs-extra": "11.0.4",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "commit-and-tag-version": "11.2.2",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-sonarjs": "4.1.0",
    "eslint-plugin-storybook": "10.4.6",
    "fs-extra": "11.3.6",
    "globals": "17.7.0",
    "playwright": "1.56.1",
    "prettier": "3.9.4",
    "storybook": "10.4.6",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.2",
    "vite-plugin-dts": "5.0.3",
    "vite-plugin-lib-inject-css": "2.2.2",
    "vitest": "4.1.9"
  }
}
