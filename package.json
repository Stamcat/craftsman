{
  "name": "@stamcat/craftsman",
  "version": "0.0.22",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stamcat/craftsman"
  },
  "scripts": {
    "build": "tsc --p ./tsconfig-build.json && vite build && tsx ./buildPackage.ts",
    "build-storybook": "storybook build",
    "dev": "vite",
    "lint": "eslint . && npm run lint:package",
    "lint:fix": "eslint . --fix",
    "lint:package": "npmPkgJsonLint ./package.json",
    "prepublishOnly": "node ./scripts/prepublishCheck.js",
    "preview": "vite preview",
    "release": "commit-and-tag-version",
    "release:alpha": "npm run release -- --prerelease alpha",
    "release:beta": "npm run release -- --prerelease beta",
    "release:major": "npm run release -- release-as major",
    "release:minor": "npm run release -- release-as minor",
    "release:patch": "npm run release -- release-as patch",
    "storybook": "storybook dev -p 6006",
    "type-check": "tsc --noEmit"
  },
  "exports": {
    "./Button": {
      "types": "./Button.d.ts",
      "default": "./Button.es.js"
    }
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "dompurify": "3.2.6",
    "emotion": "11.0.0",
    "react": "19.1.1",
    "react-date-picker": "12.0.1",
    "react-datetime-picker": "7.0.1",
    "react-dom": "19.1.1",
    "react-international-phone": "4.6.0",
    "zod": "4.1.9"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "4.1.1",
    "@eslint/js": "9.35.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@storybook/addon-a11y": "9.1.7",
    "@storybook/addon-docs": "9.1.7",
    "@storybook/addon-themes": "9.1.7",
    "@storybook/addon-vitest": "9.1.7",
    "@storybook/react-vite": "9.1.7",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.5.2",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.2",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "commit-and-tag-version": "11.2.2",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-storybook": "9.1.7",
    "fs-extra": "11.3.2",
    "globals": "16.4.0",
    "npm-package-json-lint": "10.4.0",
    "npm-package-json-lint-config-default": "9.0.1",
    "playwright": "1.56.1",
    "prettier": "3.8.3",
    "storybook": "9.1.7",
    "tsx": "4.20.5",
    "typescript": "5.8.2",
    "typescript-eslint": "8.43.0",
    "vite": "7.1.11",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-lib-inject-css": "2.2.2",
    "vitest": "3.2.4"
  }
}
