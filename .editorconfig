root = true

# These settings are honored by many editors and tools
# Try to change settings here first before changing in
# a specific tool e.g. VSCode, Prettier

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = false
insert_final_newline = true
max_line_length = 120


[*.json]
indent_size = 2
